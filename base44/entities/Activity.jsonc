{
  "name": "Activity",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "facet": {
      "type": "string",
      "enum": [
        "LEARN",
        "DEFINE",
        "COMMIT",
        "DESCRIBE",
        "CREATE",
        "PREPARE",
        "DELIVER"
      ]
    },
    "preferred_owner": {
      "type": "string"
    },
    "sort_order": {
      "type": "number"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "assessment_id": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "facet"
  ],
  "rls": {
    "create": {
      "$or": [
        { "user_condition": { "role": "admin" } },
        { "user_condition": { "role": "org_admin" } },
        { "user_condition": { "role": "facilitator" } }
      ]
    },
    "read": {},
    "update": {
      "$or": [
        { "user_condition": { "role": "admin" } },
        { "user_condition": { "role": "org_admin" } },
        { "user_condition": { "role": "facilitator" } }
      ]
    },
    "delete": {
      "$or": [
        { "user_condition": { "role": "admin" } },
        { "user_condition": { "role": "org_admin" } },
        { "user_condition": { "role": "facilitator" } }
      ]
    }
  }
}