{
  "name": "Assessment",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "tagline": {
      "type": "string"
    },
    "company_name": {
      "type": "string"
    },
    "access_code": {
      "type": "string"
    },
    "buyer_token": {
      "type": "string"
    },
    "team_token": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "closed"
      ],
      "default": "draft"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "activity_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "collaborator_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "required": [
    "title",
    "access_code"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "facilitator"
          }
        }
      ]
    },
    "read": {},
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "facilitator"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}