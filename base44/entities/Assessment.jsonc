{
  "name": "Assessment",
  "properties": {
    "title": { "type": "string" },
    "company_name": { "type": "string" },
    "access_code": { "type": "string" },
    "buyer_token": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "closed"], "default": "draft" },
    "roles": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["title", "access_code"]
}
